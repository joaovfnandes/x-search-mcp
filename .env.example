# Transporte usado para conectar ao CUA MCP.
CUA_TRANSPORT=stdio

# Para stdio: comando que inicia o seu CUA MCP.
CUA_COMMAND=C:\Users\User\AppData\Local\Programs\Cua\cua-driver\bin\cua-driver.exe
CUA_ARGS_JSON=["mcp"]

# Para HTTP, use CUA_TRANSPORT=http e informe o endpoint MCP.
# CUA_URL=http://localhost:3000/mcp
